{
  "expo": {
    "name": "Aile Bütçesi",
    "slug": "family-budget",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "familybudget",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ailebutcesi2026.app",
      "buildNumber": "3",
      "infoPlist": {
        "NSCameraUsageDescription": "Fiş ve fatura taramak için kameraya erişim gerekiyor.",
        "NSMicrophoneUsageDescription": "Sesli asistan için mikrofona erişim gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Fiş fotoğraflarını seçmek için galeriye erişim gerekiyor."
      }
    },
    "android": {
      "package": "com.ailebutcesi2026.app",
      "versionCode": 3,
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-mail-composer",
      [
        "expo-image-picker",
        {
          "photosPermission": "Fiş fotoğraflarını seçmek için galeriye erişim gerekiyor.",
          "cameraPermission": "Fiş ve fatura taramak için kameraya erişim gerekiyor."
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
